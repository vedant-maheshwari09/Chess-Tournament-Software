# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/chess_db
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_PASSWORD=your_db_password

# Authentication
SESSION_SECRET=your_random_session_secret

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
NOTIFY_EMAIL_USER=your_email@gmail.com
NOTIFY_EMAIL_PASSWORD=your_app_password
NOTIFY_FROM_EMAIL=Chess TD <your_email@gmail.com>

# Payments (Stripe)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# AI (Optional)
GEMINI_API_KEY=your_gemini_api_key

# Firebase (Notifications)
GOOGLE_CLOUD_PROJECT=your_project_id
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key

# External Rating Sources (URLs to rating files)
USCF_BLITZ_URL=https://example.com/USCF_BLITZ.txt
USCF_QUICK_URL=https://example.com/USCF_QUICK.txt
FIDE_PLAYER_LIST_URL=https://example.com/FIDE_PLAYERS.txt
